# Production environment values — copy to prod.tfvars and fill in before applying
# terraform apply -var-file="envs/prod.tfvars"

aws_region         = "us-east-1"
environment        = "prod"
cluster_name       = "coffee-shop-prod"
kubernetes_version = "1.29"

# t3.large: 2 vCPU, 8 GB RAM — more headroom for production traffic
node_instance_type = "t3.large"
node_desired_size  = 2
node_min_size      = 2
node_max_size      = 4
